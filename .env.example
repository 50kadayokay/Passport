# Passport environment variables
# Copy to .env for local dev, and set the same keys in Vercel (Project → Settings → Environment Variables).
# Both values are PUBLISHABLE (safe in the browser bundle). NEVER put the Supabase
# service_role / secret key in a VITE_ variable — those are inlined into the client bundle.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXX
